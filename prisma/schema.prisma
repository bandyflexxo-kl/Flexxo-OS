// ============================================================
// DOMAIN 11B — PRIVATE-PARTNER DELIVERY RUNS
// Compounds several packed orders into one WhatsApp job for the
// private delivery partner. Priced by the farthest stop (Decision B):
// trip distance = max(stop km), quantity = sum of boxes/pallets.
// ============================================================

model DeliveryRun {
  id          String    @id @default(uuid())
  mode        String    @default("parcel")          // 'parcel' | 'pallet'
  status      String    @default("draft")           // draft | dispatched | completed | cancelled
  maxKm       Int       @default(0) @map("max_km")  // farthest stop — drives the trip price
  totalQty    Int       @default(0) @map("total_qty") // total boxes or pallets across stops
  priceMyr    Decimal?  @map("price_myr") @db.Decimal(10, 2)
  partnerJid  String?   @map("partner_jid")         // WhatsApp group JID the job was sent to
  messageText String?   @map("message_text") @db.Text
  notes       String?   @db.Text
  sentAt      DateTime? @map("sent_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  createdById String    @map("created_by")

  createdBy User              @relation("DeliveryRunCreated", fields: [createdById], references: [id])
  stops     DeliveryRunStop[]

  @@map("delivery_runs")
}

model DeliveryRunStop {
  id           String  @id @default(uuid())
  runId        String  @map("run_id")
  orderId      String  @map("order_id")
  sequence     Int     @default(0)
  zone         String?                              // confirmed zone label
  km           Int     @default(0)                  // confirmed distance for this stop
  qty          Int     @default(0)                  // boxes or pallets for this stop
  address      String? @db.Text                     // confirmed address snapshot (admin-edited)
  contactName  String? @map("contact_name")
  contactPhone String? @map("contact_phone")

  run   DeliveryRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  order Order       @relation(fields: [orderId], references: [id])

  @@map("delivery_run_stops")
}

// ============================================================
// DOMAIN 12 — QNE SIMULATION LAYER
// Every operation that would write to QNE is staged here first.
// Bandy reviews monthly and manually enters approved records in QNE,
// preserving the original business date (not the approval date).
// ============================================================

model QnePendingAction {
  id           String    @id @default(uuid())
  actionType   String    @map("action_type")   // 'invoice' | 'delivery_order' | 'quotation' | 'sales_order'
  referenceNo  String    @map("reference_no")  // e.g. "INV-2026-0001"
  originalDate DateTime  @map("original_date") // actual business date — use this when entering in QNE
  payload      Json      @default("{}")        // full data snapshot (items, amounts, customer, etc.)
  status       String    @default("pending")   // pending | approved | rejected
  notes        String?   @db.Text
  approvedById String?   @map("approved_by")
  approvedAt   DateTime? @map("approved_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  approvedBy User? @relation("QnePendingActionApprovedBy", fields: [approvedById], references: [id])

  @@index([status, createdAt])
  @@map("qne_pending_actions")
}

// Records each CRM document that has been (or is being) pushed to QNE as part of
// the QT→SO→DO→Invoice chain. Stores the QNE doc id + code, and a per-line
// detail-id map (lineMap: { crmItemId: qneDetailId }) that the NEXT document in
// the chain reads to populate its `transferFrom` links. One row per (docType, crmId).
model QneDocLink {
  id         String    @id @default(uuid())
  docType    String    @map("doc_type")    // quotation | sales_order | delivery_order | invoice
  crmId      String    @map("crm_id")       // CRM quotation.id (quotation) or order.id (SO/DO/invoice)
  branchCode String    @default("KL") @map("branch_code")
  qneId      String?   @map("qne_id")       // QNE document UUID (for QuotationToInvoice + idempotency)
  qneCode    String?   @map("qne_code")     // QNE document code, e.g. "QT KL2606/0079"
  status     String    @default("pending")  // pending | synced | failed
  error      String?   @db.Text
  lineMap    Json?     @map("line_map")     // { crmItemId: qneDetailId } → downstream transferFrom
  pushedAt   DateTime? @map("pushed_at")
  pushedById String?   @map("pushed_by")    // plain ref (audit_log trigger captures the real audit)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@unique([docType, crmId])
  @@index([crmId])
  @@map("qne_doc_links")
}

// ============================================================
// DOMAIN 13 — B2B SHOP ACCOUNT REQUESTS
// Prospective buyers who click "Request Business Account"
// on the shop login page. Saved immediately so Flexxo team
// can follow up. Never auto-converted to user accounts.
// ============================================================

model AccountRequest {
  id          String    @id @default(uuid())
  fullName    String    @map("full_name")     // primary requester (= contacts[0]) — kept for back-compat
  companyName String    @map("company_name")
  email       String
  phone       String?
  message     String?   @db.Text
  contacts    Json?                            // up to 3 contacts: [{ fullName, position, department, email, phone, whatsapp, influenceLevel, isDecisionMaker }]
  status      String    @default("pending")  // pending | contacted | converted | rejected
  notes       String?   @db.Text             // internal notes from Flexxo team
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt           @map("updated_at")

  @@index([status, createdAt])
  @@map("account_requests")
}

// ============================================================
// DOMAIN 11 — TELEGRAM ACCOUNT OPENING
// Salesperson scans a name card via Telegram bot.
// Admin approves → Company + Contact created in CRM.
// ============================================================

// ============================================================
// DOMAIN 14 — BRAND SITE OVERRIDES
// Admin-curated map of brand → official search site + hint.
// Takes priority over the hardcoded brandSites.ts defaults.
// Set via /admin/brand-sites or the "Remember…" checkbox in
// the photo-resolve panel.
// ============================================================

model BrandSiteOverride {
  id        String   @id @default(uuid())
  brand     String   @unique
  site      String?
  hint      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@map("brand_site_overrides")
}

model TelegramAccountRequest {
  id                String    @id @default(uuid())
  requestedById     String    @map("requested_by_id")
  salespersonChatId String    @map("salesperson_chat_id")
  status            String    @default("pending")   // pending | approved | rejected
  companyName       String    @map("company_name")
  address           String?
  ssmNumber         String?   @map("ssm_number")
  tinNumber         String?   @map("tin_number")
  picName           String    @map("pic_name")
  picPhone          String    @map("pic_phone")
  picEmail          String?   @map("pic_email")
  createdCompanyId  String?   @map("created_company_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  requestedBy    User     @relation("TelegramAccountRequests", fields: [requestedById], references: [id])
  createdCompany Company? @relation("CompanyFromTelegramRequest", fields: [createdCompanyId], references: [id])

  @@index([status, createdAt])
  @@map("telegram_account_requests")
}

// ============================================================
// DOMAIN 15 — TENDER MANAGEMENT
// 6-stage tender lifecycle (creation → rfq → evaluation →
// client_po → supplier_po → receiving → closed) with 3 gates.
// CRM is system of record; committed POs/GRNs mirror to QNE.
// Price freezes at evaluation lock (awarded_unit_price).
// ============================================================

model Tender {
  id                   String    @id @default(uuid())
  refNo                String    @unique @map("ref_no")              // FLX-TDR-2026-0001
  name                 String
  category             String?
  mode                 String    @default("multi")                  // single | multi
  stage                String    @default("creation")               // creation|rfq|evaluation|client_po|supplier_po|receiving|closed
  status               String    @default("active")                 // active|won|lost|cancelled|expired
  periodStart          DateTime? @map("period_start")
  periodEnd            DateTime? @map("period_end")
  submissionExpiry     DateTime? @map("submission_expiry")
  expectedClientPoDate DateTime? @map("expected_client_po_date")
  estValue             Decimal?  @map("est_value") @db.Decimal(14, 2)
  competitorNotes      String?   @map("competitor_notes") @db.Text
  internalRemarks      String?   @map("internal_remarks") @db.Text
  varianceThreshold    Decimal?  @map("variance_threshold") @db.Decimal(5, 2) // null = use global setting
  minQuotesRequired    Int?      @map("min_quotes_required")
  pricesLockedAt       DateTime? @map("prices_locked_at")
  pricesLockedById     String?   @map("prices_locked_by")
  qneProjectCode       String?   @map("qne_project_code")
  gate1ApprovalId      String?   @map("gate1_approval_id")
  gate2ApprovalId      String?   @map("gate2_approval_id")
  gate3ApprovalId      String?   @map("gate3_approval_id")
  clientCompanyId      String?   @map("client_company_id")
  createdById          String    @map("created_by")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  createdBy      User             @relation("TenderCreatedBy", fields: [createdById], references: [id])
  pricesLockedBy User?            @relation("TenderPricesLockedBy", fields: [pricesLockedById], references: [id])
  clientCompany  Company?         @relation("TenderClientCompany", fields: [clientCompanyId], references: [id])
  items          TenderItem[]
  vendors        TenderVendor[]
  clientPOs      ClientPO[]
  supplierPOs    SupplierPO[]
  amendments     TenderAmendment[]
  documents      TenderDocument[]

  @@index([stage, status])
  @@index([createdById])
  @@map("tenders")
}

model TenderItem {
  id                   String   @id @default(uuid())
  tenderId             String   @map("tender_id")
  pos                  Int
  name                 String
  unit                 String?
  qty                  Decimal  @db.Decimal(12, 3)
  targetPrice          Decimal? @map("target_price") @db.Decimal(12, 4)        // client target (Stage 1)
  normalUnitPrice      Decimal? @map("normal_unit_price") @db.Decimal(12, 4)   // Drive list snapshot (Stage 3)
  normalPriceVersionId String?  @map("normal_price_version_id")                // → SupplierPriceVersion (plain ref)
  awardedUnitPrice     Decimal? @map("awarded_unit_price") @db.Decimal(12, 4)  // tender price, FROZEN at lock
  awardedSupplierId    String?  @map("awarded_supplier_id")
  matchedProductId     String?  @map("matched_product_id")
  qneStockCode         String?  @map("qne_stock_code")
  aiConfidence         Float?   @map("ai_confidence")

  tender          Tender              @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  awardedSupplier Supplier?           @relation("TenderItemAwardedSupplier", fields: [awardedSupplierId], references: [id])
  matchedProduct  Product?            @relation(fields: [matchedProductId], references: [id])
  quotes          TenderVendorQuote[]
  clientPoItems   ClientPOItem[]
  supplierPoItems SupplierPOItem[]

  @@index([tenderId])
  @@map("tender_items")
}

model TenderVendor {
  id                String    @id @default(uuid())
  tenderId          String    @map("tender_id")
  supplierId        String    @map("supplier_id")
  replyStatus       String    @default("sent") @map("reply_status")  // sent|acknowledged|price_received|no_response
  rfqSentAt         DateTime? @map("rfq_sent_at")
  acknowledgedAt    DateTime? @map("acknowledged_at")
  priceReceivedAt   DateTime? @map("price_received_at")
  quoteValidityDays Int?      @map("quote_validity_days")
  quoteValidUntil   DateTime? @map("quote_valid_until")

  tender   Tender              @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  supplier Supplier            @relation(fields: [supplierId], references: [id])
  quotes   TenderVendorQuote[]

  @@unique([tenderId, supplierId])
  @@index([tenderId])
  @@map("tender_vendors")
}

model TenderVendorQuote {
  id                   String   @id @default(uuid())
  tenderItemId         String   @map("tender_item_id")
  tenderVendorId       String   @map("tender_vendor_id")
  supplierId           String   @map("supplier_id")
  quotedUnitPrice      Decimal  @map("quoted_unit_price") @db.Decimal(12, 4)   // supplier price
  variancePct          Decimal? @map("variance_pct") @db.Decimal(6, 2)         // vs normalUnitPrice
  flaggedOverThreshold Boolean  @default(false) @map("flagged_over_threshold")
  overrideReason       String?  @map("override_reason") @db.Text
  isAwarded            Boolean  @default(false) @map("is_awarded")
  enteredById          String   @map("entered_by")
  enteredAt            DateTime @default(now()) @map("entered_at")

  tenderItem   TenderItem   @relation(fields: [tenderItemId], references: [id], onDelete: Cascade)
  tenderVendor TenderVendor @relation(fields: [tenderVendorId], references: [id], onDelete: Cascade)
  supplier     Supplier     @relation(fields: [supplierId], references: [id])
  enteredBy    User         @relation("TenderQuoteEnteredBy", fields: [enteredById], references: [id])

  @@unique([tenderItemId, tenderVendorId])
  @@index([tenderItemId])
  @@map("tender_vendor_quotes")
}

model ClientPO {
  id                String   @id @default(uuid())
  tenderId          String   @map("tender_id")
  poNumber          String   @map("po_number")
  dateReceived      DateTime @map("date_received")
  value             Decimal  @db.Decimal(14, 2)
  picName           String?  @map("pic_name")
  picEmail          String?  @map("pic_email")
  picPhone          String?  @map("pic_phone")
  qneSalesOrderCode String?  @map("qne_sales_order_code")
  recordedById      String   @map("recorded_by")
  createdAt         DateTime @default(now()) @map("created_at")

  tender     Tender         @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  recordedBy User           @relation("ClientPoRecordedBy", fields: [recordedById], references: [id])
  items      ClientPOItem[]

  @@index([tenderId])
  @@map("client_pos")
}

model ClientPOItem {
  id           String  @id @default(uuid())
  clientPoId   String  @map("client_po_id")
  tenderItemId String  @map("tender_item_id")
  qtyCovered   Decimal @map("qty_covered") @db.Decimal(12, 3)
  value        Decimal @db.Decimal(14, 2)

  clientPo   ClientPO   @relation(fields: [clientPoId], references: [id], onDelete: Cascade)
  tenderItem TenderItem @relation(fields: [tenderItemId], references: [id], onDelete: Cascade)

  @@index([clientPoId])
  @@map("client_po_items")
}

model SupplierPO {
  id                String    @id @default(uuid())
  tenderId          String    @map("tender_id")
  supplierId        String    @map("supplier_id")
  poNumber          String    @unique @map("po_number")
  status            String    @default("issued")  // issued|acknowledged|partially_received|received|closed
  deliveryDate      DateTime? @map("delivery_date")
  deliveryLocation  String?   @map("delivery_location")
  ackDate           DateTime? @map("ack_date")
  supplierRef       String?   @map("supplier_ref")
  priceValidityDate DateTime? @map("price_validity_date")  // = tender expiry
  qnePoCode         String?   @map("qne_po_code")
  issuedById        String    @map("issued_by")
  issuedAt          DateTime  @default(now()) @map("issued_at")

  tender   Tender           @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  supplier Supplier         @relation(fields: [supplierId], references: [id])
  issuedBy User             @relation("SupplierPoIssuedBy", fields: [issuedById], references: [id])
  items    SupplierPOItem[]
  grns     GoodsReceipt[]

  @@index([tenderId])
  @@map("supplier_pos")
}

model SupplierPOItem {
  id           String  @id @default(uuid())
  supplierPoId String  @map("supplier_po_id")
  tenderItemId String  @map("tender_item_id")
  qty          Decimal @db.Decimal(12, 3)
  unitPrice    Decimal @map("unit_price") @db.Decimal(12, 4)   // from awardedUnitPrice — immutable

  supplierPo SupplierPO @relation(fields: [supplierPoId], references: [id], onDelete: Cascade)
  tenderItem TenderItem @relation(fields: [tenderItemId], references: [id], onDelete: Cascade)
  grnItems   GRNItem[]

  @@index([supplierPoId])
  @@map("supplier_po_items")
}

model GoodsReceipt {
  id           String   @id @default(uuid())
  supplierPoId String   @map("supplier_po_id")
  grnNumber    String   @unique @map("grn_number")
  receivedById String   @map("received_by")
  receivedAt   DateTime @default(now()) @map("received_at")
  photoUrl     String?  @map("photo_url")
  closed       Boolean  @default(false)   // manual close only
  qneGrnCode   String?  @map("qne_grn_code")

  supplierPo SupplierPO @relation(fields: [supplierPoId], references: [id], onDelete: Cascade)
  receivedBy User       @relation("GoodsReceivedBy", fields: [receivedById], references: [id])
  items      GRNItem[]

  @@index([supplierPoId])
  @@map("goods_receipts")
}

model GRNItem {
  id               String  @id @default(uuid())
  grnId            String  @map("grn_id")
  supplierPoItemId String  @map("supplier_po_item_id")
  qtyReceived      Decimal @map("qty_received") @db.Decimal(12, 3)
  rejectQty        Decimal @default(0) @map("reject_qty") @db.Decimal(12, 3)
  rejectReason     String? @map("reject_reason") @db.Text

  grn            GoodsReceipt   @relation(fields: [grnId], references: [id], onDelete: Cascade)
  supplierPoItem SupplierPOItem @relation(fields: [supplierPoItemId], references: [id], onDelete: Cascade)

  @@index([grnId])
  @@map("grn_items")
}

model TenderAmendment {
  id           String   @id @default(uuid())
  tenderId     String   @map("tender_id")
  field        String
  beforeVal    String?  @map("before_val") @db.Text
  afterVal     String?  @map("after_val") @db.Text
  reason       String?  @db.Text
  changedById  String   @map("changed_by")
  approvedById String?  @map("approved_by")
  createdAt    DateTime @default(now()) @map("created_at")

  tender     Tender @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  changedBy  User   @relation("TenderAmendmentChangedBy", fields: [changedById], references: [id])
  approvedBy User?  @relation("TenderAmendmentApprovedBy", fields: [approvedById], references: [id])

  @@index([tenderId])
  @@map("tender_amendments")
}

model TenderDocument {
  id         String   @id @default(uuid())
  tenderId   String   @map("tender_id")
  docType    String   @map("doc_type")   // client_attachment|rfq_pdf|po_pdf|evaluation_pdf|grn_photo
  fileName   String   @map("file_name")
  storageUrl String   @map("storage_url")
  supplierId String?  @map("supplier_id")
  createdAt  DateTime @default(now()) @map("created_at")

  tender   Tender    @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  supplier Supplier? @relation(fields: [supplierId], references: [id])

  @@index([tenderId])
  @@map("tender_documents")
}

model SupplierPerformance {
  id                   String   @id @default(uuid())
  supplierId           String   @unique @map("supplier_id")
  avgReplyHours        Float?   @map("avg_reply_hours")
  winRate              Float?   @map("win_rate")
  priceCompetitiveness Float?   @map("price_competitiveness")
  deliveryReliability  Float?   @map("delivery_reliability")
  tendersInvited       Int      @default(0) @map("tenders_invited")
  tendersWon           Int      @default(0) @map("tenders_won")
  updatedAt            DateTime @updatedAt @map("updated_at")

  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@map("supplier_performance")
}
