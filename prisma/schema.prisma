// ============================================================
// DOMAIN 7 — QUOTATION
// ============================================================

model Quotation {
  id                String    @id @default(uuid())
  companyId         String    @map("company_id")
  contactId         String?   @map("contact_id")
  createdById       String    @map("created_by")
  approvedById      String?   @map("approved_by")
  parentQuotationId String?   @map("parent_quotation_id")
  versionNumber     Int       @default(1) @map("version_number")
  referenceNo       String    @map("reference_no")
  status            String    @default("draft")
  currency          String    @default("MYR")
  subtotal          Decimal?  @db.Decimal(14, 4)
  discountAmount    Decimal?  @map("discount_amount") @db.Decimal(14, 4)
  taxAmount         Decimal?  @map("tax_amount") @db.Decimal(14, 4)
  totalAmount       Decimal?  @map("total_amount") @db.Decimal(14, 4)
  poNumber          String?   @map("po_number") @db.VarChar(100)
  costCentre        String?   @map("cost_centre") @db.VarChar(100)
  termsConditions   String?   @map("terms_conditions") @db.Text
  internalNotes     String?   @map("internal_notes") @db.Text
  isArchived        Boolean   @default(false) @map("is_archived")
  deliveryAddress   String?   @map("delivery_address") @db.Text
  deliveryRecipient String?   @map("delivery_recipient") @db.VarChar(200)
  deliveryPhone     String?   @map("delivery_phone") @db.VarChar(50)
  deliveryAddressId String?   @map("delivery_address_id")  // saved CompanyAddress chosen at checkout
  sentAt            DateTime? @map("sent_at")
  expiresAt         DateTime? @map("expires_at")
  clientAmended     Boolean   @default(false) @map("client_amended")
  clientAmendedAt   DateTime? @map("client_amended_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  company          Company                  @relation(fields: [companyId], references: [id])
  contact          Contact?                 @relation(fields: [contactId], references: [id])
  deliveryAddressRef CompanyAddress?         @relation(fields: [deliveryAddressId], references: [id])
  createdBy        User                     @relation("QuotationCreatedBy", fields: [createdById], references: [id])
  approvedBy       User?                    @relation("QuotationApprovedBy", fields: [approvedById], references: [id])
  parentQuotation  Quotation?               @relation("QuotationRevision", fields: [parentQuotationId], references: [id])
  revisedVersions  Quotation[]              @relation("QuotationRevision")
  items            QuotationItem[]
  statusHistory    QuotationStatusHistory[]
  orders           Order[]

  @@map("quotations")
}

model QuotationItem {
  id                     String    @id @default(uuid())
  quotationId            String    @map("quotation_id")
  productId              String?   @map("product_id")
  supplierPriceVersionId String?   @map("supplier_price_version_id")
  description            String
  brand                  String?
  unit                   String?
  qty                    Decimal   @db.Decimal(12, 4)
  unitCost               Decimal?  @map("unit_cost") @db.Decimal(12, 4)
  unitPrice              Decimal   @map("unit_price") @db.Decimal(12, 4)
  marginPct              Decimal?  @map("margin_pct") @db.Decimal(6, 4)
  discountPct            Decimal?  @map("discount_pct") @db.Decimal(6, 4)
  lineTotal              Decimal   @map("line_total") @db.Decimal(14, 4)
  sortOrder              Int       @default(0) @map("sort_order")

  quotation            Quotation             @relation(fields: [quotationId], references: [id])
  product              Product?              @relation(fields: [productId], references: [id])
  supplierPriceVersion SupplierPriceVersion? @relation(fields: [supplierPriceVersionId], references: [id])
  orderItems           OrderItem[]

  @@map("quotation_items")
}

model QuotationStatusHistory {
  id          String   @id @default(uuid())
  quotationId String   @map("quotation_id")
  fromStatus  String?  @map("from_status")
  toStatus    String   @map("to_status")
