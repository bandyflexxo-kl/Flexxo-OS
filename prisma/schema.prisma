// ============================================================
// FLEXXO SALES OS — ENTERPRISE PRISMA SCHEMA v1.0
// Conservative enterprise design: staging-first, approval-gated,
// fully audited. QNE is system of record. AI suggests only.
// All PKs are UUIDs. All FKs are explicit named relations.
// Sensitive tables are audit-logged via PostgreSQL triggers.
// ============================================================

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// DOMAIN 1 — IDENTITY
// ============================================================

model User {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  passwordHash String    @map("password_hash")
  isActive            Boolean   @default(true) @map("is_active")
  mustChangePassword  Boolean   @default(false) @map("must_change_password")
  mobileNo            String?   @map("mobile_no")
  googleRefreshToken  String?   @map("google_refresh_token")
  telegramChatId      String?   @unique @map("telegram_chat_id")
  customerCompanyId   String?   @map("customer_company_id")
  lastLoginAt         DateTime? @map("last_login_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  userRoles                 UserRole[]
  companyAssignments        CompanyAssignment[]
  activitiesPerformed       Activity[]
  quotationsCreated         Quotation[]              @relation("QuotationCreatedBy")
  quotationsApproved        Quotation[]              @relation("QuotationApprovedBy")
  approvalRequestsMade      ApprovalRequest[]        @relation("ApprovalRequestedBy")
  approvalRequestsAssigned  ApprovalRequest[]        @relation("ApprovalAssignedTo")
  stageChanges              PipelineStageHistory[]
  companyTags               CompanyTag[]
  auditLogs                 AuditLog[]
  priceVersionsApproved     SupplierPriceVersion[]
  priceFilesUploaded        SupplierPriceFile[]
  priceStagingReviewed      SupplierPriceStaging[]
  qneSyncsTriggered         QneSyncLog[]
  qneStagingReviewed        QneCustomerStaging[]
  duplicatesResolved        DuplicateDetectionQueue[]
  companiesCreated          Company[]
  contactsCreated           Contact[]
  productsCreated           Product[]
  ordersCreated             Order[]
  matchesConfirmed          ProductSupplierMatch[]
  quotationStatusChanges    QuotationStatusHistory[]
  customerCompany           Company?                  @relation("CustomerPortalUser", fields: [customerCompanyId], references: [id])
  pushSubscriptions         PushSubscription[]
  invoicesIssued            Invoice[]                 @relation("InvoiceIssuedBy")
  warehouseTasksCompleted   WarehouseTask[]           @relation("WarehouseTaskCompleted")
  deliveryRunsCreated       DeliveryRun[]             @relation("DeliveryRunCreated")
  qnePendingActionsApproved QnePendingAction[]        @relation("QnePendingActionApprovedBy")
  telegramAccountRequests   TelegramAccountRequest[]  @relation("TelegramAccountRequests")
  aliasesCreated            ProductAlias[]            @relation("AliasCreator")
  contactEditRequests       ContactEditRequest[]       @relation("ContactEditRequestedBy")
  contactEditApprovals      ContactEditRequest[]       @relation("ContactEditApprovedBy")
  tendersCreated            Tender[]                   @relation("TenderCreatedBy")
  tendersPricesLocked       Tender[]                   @relation("TenderPricesLockedBy")
  tenderQuotesEntered       TenderVendorQuote[]        @relation("TenderQuoteEnteredBy")
  clientPosRecorded         ClientPO[]                 @relation("ClientPoRecordedBy")
  supplierPosIssued         SupplierPO[]               @relation("SupplierPoIssuedBy")
  goodsReceiptsReceived     GoodsReceipt[]             @relation("GoodsReceivedBy")
  tenderAmendmentsChanged   TenderAmendment[]          @relation("TenderAmendmentChangedBy")
  tenderAmendmentsApproved  TenderAmendment[]          @relation("TenderAmendmentApprovedBy")

  @@map("users")
}

model Role {
  id          String     @id @default(uuid())
  name        String     @unique
  description String?

  userRoles   UserRole[]

  @@map("roles")
}

model UserRole {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  roleId    String    @map("role_id")
  grantedAt DateTime  @default(now()) @map("granted_at")
  revokedAt DateTime? @map("revoked_at")

  user      User      @relation(fields: [userId], references: [id])
  role      Role      @relation(fields: [roleId], references: [id])

  @@map("user_roles")
}

// ============================================================
// DOMAIN 2 — CRM: COMPANIES & CONTACTS
// ============================================================

model Company {
  id                 String    @id @default(uuid())
  name               String
  nameNormalized     String    @map("name_normalized")
  regNumber          String?   @map("reg_number")
  tinNumber          String?   @map("tin_number")
  industry           String?
  companySize        String?   @map("company_size")
  generalEmail       String?   @map("general_email")
  mainPhone          String?   @map("main_phone")
  website            String?
  leadSource         String?   @map("lead_source")
  leadTemperature    String?   @map("lead_temperature")
  status             String    @default("Lead") @map("status")
  qneCustomerCode      String?   @unique @map("qne_customer_code")
  qneSynced            Boolean   @default(false) @map("qne_synced")
  qneLastSyncedAt      DateTime? @map("qne_last_synced_at")
  outstandingBalance   Decimal?  @map("outstanding_balance")
  creditLimit          Decimal?  @map("credit_limit")
  overdueAmount        Decimal?  @map("overdue_amount")
  discountPct          Decimal?  @map("discount_pct") @db.Decimal(5, 2)   // standing customer discount % applied to their quotes
  outstandingUpdatedAt DateTime? @map("outstanding_updated_at")
  isDuplicateSuspect   Boolean   @default(false) @map("is_duplicate_suspect")
  mergedIntoId         String?   @map("merged_into_id")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  createdById          String    @map("created_by")

  createdBy           User                      @relation(fields: [createdById], references: [id])
  mergedInto          Company?                  @relation("CompanyMerge", fields: [mergedIntoId], references: [id])
  mergedFrom          Company[]                 @relation("CompanyMerge")
  contacts            Contact[]
  addresses           CompanyAddress[]
  tags                CompanyTag[]
  productInterests    CompanyProductInterest[]
  assignments         CompanyAssignment[]
  pipelineHistory     PipelineStageHistory[]
  activities          Activity[]
  quotations          Quotation[]
  orders              Order[]
  duplicateCandidateA DuplicateDetectionQueue[] @relation("DuplicateCandidateA")
  duplicateCandidateB DuplicateDetectionQueue[] @relation("DuplicateCandidateB")
  qneStagingMatches   QneCustomerStaging[]
  portalUsers         User[]                    @relation("CustomerPortalUser")
  invoices                 Invoice[]
  topItems                 QneTopItem[]
  qneInvoices              QneInvoice[]
  qneQuotations            QneQuotation[]
  qneSalesOrders           QneSalesOrder[]
  qneDeliveryOrders        QneDeliveryOrder[]
  telegramAccountRequests  TelegramAccountRequest[]  @relation("CompanyFromTelegramRequest")
  tenders                  Tender[]                  @relation("TenderClientCompany")

  @@map("companies")
}

model Contact {
  id              String    @id @default(uuid())
  companyId       String    @map("company_id")
  name            String
  position        String?
  department      String?
  email           String?
  phone           String?
  whatsapp        String?
  isDecisionMaker Boolean   @default(false) @map("is_decision_maker")
  influenceLevel  String?   @map("influence_level")
  dataQualityFlag String?   @map("data_quality_flag")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  createdById     String    @map("created_by")

  company     Company    @relation(fields: [companyId], references: [id])
  createdBy   User       @relation(fields: [createdById], references: [id])
  activities  Activity[]
  quotations  Quotation[]
  editRequests ContactEditRequest[]

  @@map("contacts")
}

model ContactEditRequest {
  id            String    @id @default(uuid())
  contactId     String    @map("contact_id")
  requestedById String    @map("requested_by_id")
  approvedById  String?   @map("approved_by_id")

  changes       Json
  status        String    @default("pending")
  rejectionNote String?   @map("rejection_note")

  createdAt  DateTime  @default(now()) @map("created_at")
  approvedAt DateTime? @map("approved_at")
  rejectedAt DateTime? @map("rejected_at")

  contact     Contact @relation(fields: [contactId], references: [id])
  requestedBy User    @relation("ContactEditRequestedBy", fields: [requestedById], references: [id])
  approvedBy  User?   @relation("ContactEditApprovedBy", fields: [approvedById], references: [id])

  @@map("contact_edit_requests")
}

model CompanyAddress {
  id            String   @id @default(uuid())
  companyId     String   @map("company_id")
  addressType   String   @map("address_type")
  label         String?
  branchName    String?  @map("branch_name")       // e.g. "Flexxo KL", "HQ Store"
  contactPerson String?  @map("contact_person")    // delivery PIC name
  line1         String?
  line2         String?
  city          String?
  state         String?
  postcode      String?
  country       String   @default("Malaysia")
  phone         String?                            // delivery contact phone (for the driver)
  isDefault   Boolean  @default(false) @map("is_default")
  isActive    Boolean  @default(true) @map("is_active")
  lat         String?
  lng         String?
  // QNE branch link (Phase 1 sync). source: 'qne' = synced from QNE Branches and
  // refreshable; 'manual' = customer-added OR a synced row the customer edited
  // (edits win — the sync never overwrites a 'manual' row).
  qneBranchId   String?  @map("qne_branch_id")     // QNE Branches.id — dedupe key on re-sync
  qneBranchCode String?  @map("qne_branch_code")   // QNE branchCode e.g. "MV" — matches invoice doBranchCode (Phase 5)
  source        String   @default("manual")
  createdAt   DateTime @default(now()) @map("created_at")

  company     Company  @relation(fields: [companyId], references: [id])
  quotations  Quotation[]

  @@index([companyId, qneBranchId])
  @@map("company_addresses")
}

model Tag {
  id       String       @id @default(uuid())
  name     String       @unique
  colorHex String?      @map("color_hex")
  isActive Boolean      @default(true) @map("is_active")

  companies CompanyTag[]

  @@map("tags")
}

model CompanyTag {
  id         String   @id @default(uuid())
  companyId  String   @map("company_id")
  tagId      String   @map("tag_id")
  taggedById String   @map("tagged_by")
  taggedAt   DateTime @default(now()) @map("tagged_at")

  company  Company @relation(fields: [companyId], references: [id])
  tag      Tag     @relation(fields: [tagId], references: [id])
  taggedBy User    @relation(fields: [taggedById], references: [id])

  @@unique([companyId, tagId])
  @@map("company_tags")
}

model CompanyProductInterest {
  id         String          @id @default(uuid())
  companyId  String          @map("company_id")
  categoryId String          @map("category_id")
  createdAt  DateTime        @default(now()) @map("created_at")

  company  Company         @relation(fields: [companyId], references: [id])
  category ProductCategory @relation(fields: [categoryId], references: [id])

  @@unique([companyId, categoryId])
  @@map("company_product_interests")
}

model CompanyAssignment {
  id            String    @id @default(uuid())
  companyId     String    @map("company_id")
  userId        String    @map("user_id")
  roleInAccount String?   @map("role_in_account")
  isPrimary     Boolean   @default(false) @map("is_primary")
  assignedAt    DateTime  @default(now()) @map("assigned_at")
  unassignedAt  DateTime? @map("unassigned_at")

  company Company @relation(fields: [companyId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@map("company_assignments")
}

// ============================================================
// DOMAIN 3 — PIPELINE & ACTIVITIES
// ============================================================

model PipelineStageDefinition {
  id          String                 @id @default(uuid())
  name        String                 @unique
  sortOrder   Int                    @map("sort_order")
  colorHex    String?                @map("color_hex")
  description String?
  isActive    Boolean                @default(true) @map("is_active")

  history PipelineStageHistory[]

  @@map("pipeline_stage_definitions")
}

model PipelineStageHistory {
  id          String    @id @default(uuid())
  companyId   String    @map("company_id")
  stageId     String    @map("stage_id")
  changedById String    @map("changed_by")
  notes       String?
  enteredAt   DateTime  @default(now()) @map("entered_at")
  exitedAt    DateTime? @map("exited_at")

  company   Company                 @relation(fields: [companyId], references: [id])
  stage     PipelineStageDefinition @relation(fields: [stageId], references: [id])
  changedBy User                    @relation(fields: [changedById], references: [id])

  @@map("pipeline_stage_history")
}

model Activity {
  id               String    @id @default(uuid())
  companyId        String    @map("company_id")
  contactId        String?   @map("contact_id")
  userId           String    @map("user_id")
  activityType     String    @map("activity_type")
  subject          String
  body             String?   @db.Text
  outcome          String?
  direction        String?
  scheduledAt      DateTime? @map("scheduled_at")
  completedAt      DateTime? @map("completed_at")
  followUpAt       DateTime? @map("follow_up_at")
  followUpStatus   String?   @map("follow_up_status")
  linkedEntityType String?   @map("linked_entity_type")
  linkedEntityId   String?   @map("linked_entity_id")
  createdAt        DateTime  @default(now()) @map("created_at")

  company  Company  @relation(fields: [companyId], references: [id])
  contact  Contact? @relation(fields: [contactId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@map("activities")
}

// ============================================================
// DOMAIN 4 — PRODUCT CATALOGUE
// ============================================================

model ProductCategory {
  id               String    @id @default(uuid())
  // name is NOT unique — the same group name can exist under two different
  // parents (e.g. "Bag" under Corporate Gift AND Clothing). slug is the
  // unique key (child slugs are namespaced: parent--group).
  name             String
  slug             String    @unique
  parentCategoryId String?   @map("parent_category_id")
  isActive         Boolean   @default(true) @map("is_active")
  defaultMarginPct Decimal?  @db.Decimal(6, 2) @map("default_margin_pct")

  parentCategory   ProductCategory?         @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id])
  subCategories    ProductCategory[]        @relation("CategoryHierarchy")
  products         Product[]
  companyInterests CompanyProductInterest[]
  stagingSuggested SupplierPriceStaging[]

  @@map("product_categories")
}

model Product {
  id              String    @id @default(uuid())
  categoryId      String    @map("category_id")
  name            String
  brand           String?
  unit            String?
  packDescription String?   @map("pack_description")
  internalSku     String?   @unique @map("internal_sku")
  qneItemCode          String?   @map("qne_item_code")
  barcode              String?   @map("barcode")
  isActive             Boolean   @default(true) @map("is_active")
  catalogDescription   String?   @db.Text @map("catalog_description")
  defaultMarginPct     Decimal?  @db.Decimal(6, 2) @map("default_margin_pct")
  googleDrivePhotoId   String?   @map("google_drive_photo_id")
  photoUrl             String?   @map("photo_url")
  photoQualityFlagged  Boolean?  @map("photo_quality_flagged")
  photoQualityNote     String?   @map("photo_quality_note")
  photoApprovedByAdmin Boolean   @default(false) @map("photo_approved_by_admin")
  photoApprovalPending Boolean   @default(false) @map("photo_approval_pending")
  isVisibleToCustomers Boolean   @default(false) @map("is_visible_to_customers")
  qneLastSalePrice     Decimal?  @db.Decimal(12, 4) @map("qne_last_sale_price")
  qneLastSalePriceAt   DateTime? @map("qne_last_sale_price_at")
  customSellingPrice   Decimal?  @db.Decimal(12, 4) @map("custom_selling_price")
  // Live stock availability synced from QNE (GET /api/Stocks/available).
  // Shop hides products where (qneAvailableQty ?? 0) <= 0.
  qneAvailableQty      Int?      @map("qne_available_qty")
  qneStockSyncedAt     DateTime? @map("qne_stock_synced_at")
  // Raw QNE classification — category (top level) > group (subcategory) > class (brand)
  qneCategory          String?   @map("qne_category")
  qneGroup             String?   @map("qne_group")
  // Times this item appeared in confirmed QNE Sales Invoices (synced by syncQneInvoiceFreq.ts).
  // Used as popularity signal in Smart Order matching. More reliable than quotation count.
  qneInvoiceFreq       Int       @default(0) @map("qne_invoice_freq")
  // Push state for stock codes CREATED in the CRM and written to QNE (Part A).
  // synced     = exists in QNE (default — all imported products)
  // local_only = saved in CRM, not yet sent to QNE
  // pending    = save succeeded, QNE push queued / not yet confirmed
  // failed     = QNE rejected the push (reason in qnePushError)
  qnePushStatus        String    @default("synced") @map("qne_push_status")
  qnePushError         String?   @db.Text @map("qne_push_error")
  qnePushedAt          DateTime? @map("qne_pushed_at")
  // Frozen NewStock payload for a CRM-created product awaiting/retrying its QNE
  // push — lets the "Push to QNE" retry button re-send without re-entering the form.
  qnePushPayload       Json?     @map("qne_push_payload")
  createdAt            DateTime  @default(now()) @map("created_at")
  createdById          String    @map("created_by")

  category        ProductCategory        @relation(fields: [categoryId], references: [id])
  createdBy       User                   @relation(fields: [createdById], references: [id])
  supplierMatches ProductSupplierMatch[]
  priceVersions   SupplierPriceVersion[]
  stagingMatches  SupplierPriceStaging[]
  quotationItems  QuotationItem[]
  orderItems      OrderItem[]
  qneInvoiceItems       QneInvoiceItem[]
  qneQuotationItems     QneQuotationItem[]
  qneSalesOrderItems    QneSalesOrderItem[]
  qneDeliveryOrderItems QneDeliveryOrderItem[]
  aliases            ProductAlias[]
  tenderItems        TenderItem[]

  // Listing query: WHERE isActive=true AND isVisibleToCustomers=true ORDER BY name
  @@index([isActive, isVisibleToCustomers, name])
  // Category filter: WHERE isActive=true AND isVisibleToCustomers=true AND categoryId=?
  @@index([isActive, isVisibleToCustomers, categoryId])

  @@map("products")
}

// Smart Order alias/synonym table.
// Maps a normalised search phrase → a specific product so future Smart Order
// runs skip fuzzy matching and return the product directly at high confidence.
// Created when a salesperson manually selects a product and ticks "Remember this".
model ProductAlias {
  id          String   @id @default(uuid())
  alias       String   @unique     // normalised: lowercase, trimmed, collapsed spaces
  productId   String   @map("product_id")
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")
  createdById String?  @map("created_by_id")
  createdBy   User?    @relation("AliasCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([alias])
  @@map("product_aliases")
}

// Admin-managed map of product keywords → preferred brands for Smart Order matching.
// e.g. "eraser" → "Faber Castell" ×1.6 boost
model ProductBrandPreference {
  id              String   @id @default(uuid())
  label           String   // human label e.g. "Eraser → Faber Castell"
  keywords        String   // comma-separated trigger words e.g. "eraser"
  brands          String   // comma-separated preferred brands e.g. "Faber Castell,Staedtler"
  boostMultiplier Decimal  @default(1.6) @db.Decimal(4,2) @map("boost_multiplier")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("product_brand_preferences")
}

// ============================================================
// DOMAIN 5 — SUPPLIER & PRICING PIPELINE
// ============================================================

model Supplier {
  id             String    @id @default(uuid())
  name           String
  nameNormalized String    @map("name_normalized")
  regNumber      String?   @map("reg_number")
  paymentTerm    String?   @map("payment_term")
  currency       String    @default("MYR")
  isActive       Boolean   @default(true) @map("is_active")
  qneSupplierCode String?  @unique @map("qne_supplier_code")   // QNE company code (e.g. 800-R003) — read-only sync
  qneSyncedAt     DateTime? @map("qne_synced_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  contacts        SupplierContact[]
  priceFiles      SupplierPriceFile[]
  priceVersions   SupplierPriceVersion[]
  supplierMatches ProductSupplierMatch[]
  tenderVendors      TenderVendor[]
  tenderQuotes       TenderVendorQuote[]
  tenderItemsAwarded TenderItem[]         @relation("TenderItemAwardedSupplier")
  supplierPos        SupplierPO[]
  tenderDocuments    TenderDocument[]
  performance        SupplierPerformance?

  @@map("suppliers")
}

model SupplierContact {
  id         String   @id @default(uuid())
  supplierId String   @map("supplier_id")
  name       String
  position   String?
  email      String?
  phone      String?
  isPrimary  Boolean  @default(false) @map("is_primary")

  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@map("supplier_contacts")
}

model SupplierPriceFile {
  id                String    @id @default(uuid())
  supplierId        String    @map("supplier_id")
  fileName          String    @map("file_name")
  googleDriveFileId String?   @map("google_drive_file_id")
  googleDriveUrl    String?   @map("google_drive_url")
  fileType          String    @map("file_type")
  importStatus      String    @default("pending") @map("import_status")
  totalRowsDetected Int?      @map("total_rows_detected")
  rowsExtracted     Int?      @map("rows_extracted")
  rowsFailed        Int?      @map("rows_failed")
  fileHash          String?   @map("file_hash")
  driveModifiedTime DateTime? @map("drive_modified_time")
  uploadedById      String    @map("uploaded_by")
  uploadedAt        DateTime  @default(now()) @map("uploaded_at")
  processedAt       DateTime? @map("processed_at")

  supplier     Supplier               @relation(fields: [supplierId], references: [id])
  uploadedBy   User                   @relation(fields: [uploadedById], references: [id])
  stagingRows  SupplierPriceStaging[]
  importErrors ImportErrorLog[]

  @@map("supplier_price_files")
}

model SupplierPriceStaging {
  id                    String    @id @default(uuid())
  fileId                String    @map("file_id")
  supplierId            String    @map("supplier_id")
  rawRowNumber          Int?      @map("raw_row_number")
  rawItemName           String?   @map("raw_item_name")
  rawBrand              String?   @map("raw_brand")
  rawUnit               String?   @map("raw_unit")
  rawPackSize           String?   @map("raw_pack_size")
  rawPrice              String?   @map("raw_price")
  rawCurrency           String?   @map("raw_currency")
  rawMoq                String?   @map("raw_moq")
  rawValidity           String?   @map("raw_validity")
  parsedPrice           Decimal?  @map("parsed_price") @db.Decimal(12, 4)
  parsedCurrency        String?   @map("parsed_currency")
  parsedMoq             Int?      @map("parsed_moq")
  parsedValidUntil      DateTime? @map("parsed_valid_until")
  aiConfidenceScore     Float?    @map("ai_confidence_score")
  aiSuggestedCategoryId String?   @map("ai_suggested_category_id")
  aiSuggestedProductName String?  @map("ai_suggested_product_name")
  matchedProductId      String?   @map("matched_product_id")
  matchStatus           String?   @map("match_status")
  stagingStatus         String    @default("pending_review") @map("staging_status")
  rejectionReason       String?   @map("rejection_reason")
  reviewedById          String?   @map("reviewed_by")
  reviewedAt            DateTime? @map("reviewed_at")
  extractedAt           DateTime  @default(now()) @map("extracted_at")

  file                 SupplierPriceFile    @relation(fields: [fileId], references: [id])
  aiSuggestedCategory  ProductCategory?     @relation(fields: [aiSuggestedCategoryId], references: [id])
  matchedProduct       Product?             @relation(fields: [matchedProductId], references: [id])
  reviewedBy           User?                @relation(fields: [reviewedById], references: [id])
  promotedVersions     SupplierPriceVersion[]

  @@map("supplier_price_staging")
}

model SupplierPriceVersion {
  id              String    @id @default(uuid())
  supplierId      String    @map("supplier_id")
  productId       String    @map("product_id")
  stagingRowId    String    @map("staging_row_id")
  versionNumber   Int       @map("version_number")
  costPrice       Decimal   @map("cost_price") @db.Decimal(12, 4)
  currency        String    @default("MYR")
  minOrderQty     Int       @default(1) @map("min_order_qty")
  unit            String?
  priceValidFrom  DateTime? @map("price_valid_from")
  priceValidUntil DateTime? @map("price_valid_until")
  isCurrent       Boolean   @default(true) @map("is_current")
  sourceFileName  String?   @map("source_file_name")
  approvedById    String    @map("approved_by")
  approvedAt      DateTime  @map("approved_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  supplier        Supplier             @relation(fields: [supplierId], references: [id])
  product         Product              @relation(fields: [productId], references: [id])
  stagingRow      SupplierPriceStaging @relation(fields: [stagingRowId], references: [id])
  approvedBy      User                 @relation(fields: [approvedById], references: [id])
  supplierMatches ProductSupplierMatch[]
  quotationItems  QuotationItem[]

  @@unique([supplierId, productId, versionNumber])
  @@map("supplier_price_versions")
}

model ProductSupplierMatch {
  id                     String    @id @default(uuid())
  productId              String    @map("product_id")
  supplierPriceVersionId String    @map("supplier_price_version_id")
  supplierId             String    @map("supplier_id")
  isPreferred            Boolean   @default(false) @map("is_preferred")
  matchConfidence        String?   @map("match_confidence")
  confirmedById          String?   @map("confirmed_by")
  confirmedAt            DateTime? @map("confirmed_at")

  product              Product              @relation(fields: [productId], references: [id])
  supplierPriceVersion SupplierPriceVersion @relation(fields: [supplierPriceVersionId], references: [id])
  supplier             Supplier             @relation(fields: [supplierId], references: [id])
  confirmedBy          User?                @relation(fields: [confirmedById], references: [id])

  @@map("product_supplier_matches")
}

