# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/.next-verify/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
vercel-recovery-codes.txt

# vercel
.vercel

# claude code worktrees (local scratch)
.claude/worktrees/

# netlify
.netlify

# dev logs
dev.log

# typescript
*.tsbuildinfo
next-env.d.ts

/generated/prisma

.vercel

# sensitive / data files
flexxo-os-*.json
kch-cats.json
photo-gap-report.csv
group

# local scratch — analysis scripts, data dumps, one-off test scripts (never committed).
# NOTE: .ts is not blanket-ignored because many reusable _*.ts scripts ARE tracked,
# so one-off scratch .ts files are listed explicitly here.
scripts/*.py
scripts/*.csv
*.xlsx
scripts/_qne_products_dump.json
scripts/_aeonDashCheck.ts
scripts/_backfillBranch.ts
scripts/_clearAeonQneCache.ts
scripts/_deliveryTestCleanup.ts
scripts/_mintSession.ts
scripts/_mintShopSession.ts
scripts/_qnePdfInvestigate.ts
scripts/_seedDemoTender.ts
scripts/_seedDemoTenders.ts
scripts/_testWelcomeEmail.ts
